# ChatGPT Visible Bridge — Environment Example
# Copy this to .env and customize, or set variables directly.

# Workspace directory (default: ~/.openclaw/workspace/chatgpt-visible-bridge/)
CGW_HOME=~/.openclaw/workspace/chatgpt-visible-bridge

# Worker mode (default: mock)
# Options: mock, live
#   mock  — returns mock responses for testing
#   live  — requires a browser bridge (NOT IMPLEMENTED in MVP)
CGW_MODE=mock

# Adapter selection (default: mock)
CGW_ADAPTER=mock

# Telegram (optional notification channel only)
# These are used only for result queries, not for the core pipeline.
# Do NOT commit real tokens to the repository.
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Logging
CGW_LOG_LEVEL=INFO
